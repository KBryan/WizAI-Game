# ── Agentic Engineering Framework ──
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required vs Optional:
#   [Required]  = Must be set for the framework to work
#   [Optional]  = Only needed for specific features/providers
#   [Generated] = Auto-detected by scripts (can be left empty)

# ── Git Identity ──
# Used by ADW scripts when creating commits. If unset, falls back to git config.
GIT_USER_NAME=                  # [Optional] Your git user name
GIT_USER_EMAIL=                 # [Optional] Your git user email
GIT_SIGNING_KEY=                # [Optional] GPG key ID for signed commits

# ── GitHub ──
GITHUB_PAT=                     # [Optional] Only if using a different account than 'gh auth login'

# ── Agent Provider ──
# Choose which agent backend to use:
#   opencode   (default) — OpenCode CLI, supports Venice.AI or Anthropic as LLM
#   claude_cli — Claude Code CLI (requires ANTHROPIC_API_KEY)
#   venice_api — Venice.AI API directly (requires VENICE_API_KEY)
ADW_AGENT_PROVIDER=opencode

# ── OpenCode ──
OPENCODE_PATH=opencode          # [Optional] Path to OpenCode CLI

# ── Claude Code CLI (for claude_cli provider) ──
ANTHROPIC_API_KEY=              # [Required if provider=claude_cli]
CLAUDE_CODE_PATH=claude         # [Optional] Path to Claude Code CLI

# ── Venice.AI (for venice_api provider, or as OpenCode LLM backend) ──
VENICE_API_KEY=                 # [Required if provider=venice_api]
VENICE_MODEL=zai-org-glm-5-1    # [Optional] Venice model ID
VENICE_API_BASE_URL=https://api.venice.ai/api/v1  # [Optional] Custom Venice API base URL

# ── Service Ports ──
# Used by scripts/start.sh for auto-discovery
FRONTEND_PORT=3000              # [Optional] Default frontend port (Vite dev server)

# ── Webhook / Tunnel ──
PORT=8001                       # [Optional] Webhook server port
CLOUDFLARED_TUNNEL_TOKEN=       # [Optional] For expose_webhook.sh
